generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  username      String          @id
  password      String
  tipe_pengguna String
  hasil         hasil[]
  saham         saham[]
  user_kriteria user_kriteria[]
}

model saham {
  kode_saham      String      @id
  nama_perusahaan String
  harga           Int         @default(0)
  per             Float
  pbv             Float
  roe             Float
  der             Float
  eps_growth      Float
  sektor          String      @default("Perbankan")
  username        String?
  hasil           hasil[]
  penilaian       penilaian[]
  users           users?      @relation(fields: [username], references: [username])

  @@index([username], map: "saham_username_fkey")
}

model kriteria {
  kode_kriteria String          @id
  nama_kriteria String
  bobot         Float
  tipe          String
  penilaian     penilaian[]
  user_kriteria user_kriteria[]
}

model penilaian {
  kode_penilaian String   @id
  kode_saham     String
  kode_kriteria  String
  nilai          Float
  kriteria       kriteria @relation(fields: [kode_kriteria], references: [kode_kriteria])
  saham          saham    @relation(fields: [kode_saham], references: [kode_saham])

  @@index([kode_kriteria], map: "penilaian_kode_kriteria_fkey")
  @@index([kode_saham], map: "penilaian_kode_saham_fkey")
}

model hasil {
  kode_hasil       String @id
  username         String
  kode_saham       String
  nilai_preferensi Float
  ranking          Int
  saham            saham  @relation(fields: [kode_saham], references: [kode_saham])
  users            users  @relation(fields: [username], references: [username])

  @@index([kode_saham], map: "hasil_kode_saham_fkey")
  @@index([username], map: "hasil_username_fkey")
}

model user_kriteria {
  username      String
  kode_kriteria String
  bobot         Float
  kriteria      kriteria @relation(fields: [kode_kriteria], references: [kode_kriteria])
  users         users    @relation(fields: [username], references: [username])

  @@id([username, kode_kriteria])
  @@index([kode_kriteria], map: "user_kriteria_kode_kriteria_fkey")
}
